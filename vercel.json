{
  "version": 2,
  "functions": {
    "server/server.js": {
      "includeFiles": "server/**",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/server.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/client/index.html"
    }
  ]
}
